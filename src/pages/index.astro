---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Hero from "../components/Hero.astro";
import InfoCard from "../components/InfoCard.astro";
import ProofSection from "../components/ProofSection.astro";
import StepsSection from "../components/StepsSection.astro";
---

<BaseLayout
  title="Awesomesauce Plex Server | Join, Browse, Request"
  description="A cleaner home for your Facebook group's Plex server, with a real preview, join flow, and library links."
>
  <NavBar />
  <Hero />
  <ProofSection />
  <StepsSection />

  <section id="library" class="py-8 sm:py-12">
    <div class="section-shell">
      <div class="mb-6">
        <h2 class="text-3xl font-black tracking-tight sm:text-4xl">Library and requests</h2>
        <p class="mt-3 max-w-2xl text-white/70">
          Give people one place to check what is available before they ask for something new.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <InfoCard
          title="Browse what is already there"
          body="Use your Google Sheet or any other library list so people can self-check before messaging you."
        />
        <InfoCard
          title="Keep requests organized"
          body="A request form works much better than scattered Facebook comments and DMs."
        />
        <InfoCard
          title="Make the group feel active"
          body="A site like this makes the server feel maintained, real, and worth joining."
        />
      </div>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a href="https://YOUR-GOOGLE-SHEET-LINK-HERE.com" class="btn-primary">Open Library Sheet</a>
        <a href="mailto:fuzmaster69@gmail.com" class="btn-secondary">Email Contact</a>
      </div>
    </div>
  </section>

  <section id="faq" class="py-8 sm:py-12">
    <div class="section-shell">
      <div class="mb-6">
        <h2 class="text-3xl font-black tracking-tight sm:text-4xl">FAQ</h2>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <div class="card-glass p-6">
          <h3 class="text-lg font-bold">How do I get access?</h3>
          <p class="mt-3 text-white/70">
            Make a Plex account first, then use the join request link and include the same email.
          </p>
        </div>

        <div class="card-glass p-6">
          <h3 class="text-lg font-bold">Can I request movies or shows?</h3>
          <p class="mt-3 text-white/70">
            Yes. Check the library first, then send the request through the preferred path.
          </p>
        </div>

        <div class="card-glass p-6">
          <h3 class="text-lg font-bold">Do I need to pay?</h3>
          <p class="mt-3 text-white/70">
            No. If you keep a support option, frame it as optional help with upgrades and storage.
          </p>
        </div>

        <div class="card-glass p-6">
          <h3 class="text-lg font-bold">Why make a site for this?</h3>
          <p class="mt-3 text-white/70">
            Because a dedicated page is cleaner than burying everything inside a Facebook group post.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="support" class="py-8 sm:py-12">
    <div class="section-shell">
      <div class="card-glass flex flex-col gap-5 p-6 md:flex-row md:items-center md:justify-between">
        <div>
          <h2 class="text-2xl font-black tracking-tight">Optional support</h2>
          <p class="mt-3 max-w-2xl text-white/70">
            If the server is useful and you want to help with storage, maintenance, or future upgrades,
            you can support it here. Keep it optional and low-pressure.
          </p>
        </div>

        <a href="https://YOUR-DONATION-LINK-HERE.com" class="btn-secondary">
          Support the Server
        </a>
      </div>
    </div>
  </section>

  <footer class="py-10">
    <div class="section-shell">
      <div class="card-glass flex flex-col gap-5 p-6 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-lg font-bold">Awesomesauce Plex Server</p>
          <p class="mt-2 text-white/70">
            A cleaner home for your Facebook group’s shared server.
          </p>
        </div>

        <div class="flex flex-wrap gap-4 text-sm text-white/70">
          <a href="#preview" class="hover:text-white">Preview</a>
          <a href="#how" class="hover:text-white">How to Join</a>
          <a href="#library" class="hover:text-white">Library</a>
          <a href="mailto:fuzmaster69@gmail.com" class="hover:text-white">Contact</a>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>